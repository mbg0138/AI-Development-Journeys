# Copy to .env and fill in values (never commit .env)

# Optional API key (Open-Meteo commercial / other providers)
API_KEY=

# Default coordinates when /weather query params are omitted
WEATHER_LATITUDE=41.0082
WEATHER_LONGITUDE=28.9784

# Nominatim requires a descriptive User-Agent with contact info
NOMINATIM_USER_AGENT=your-app-name/1.0 (you@example.com)

# Optional API overrides
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
GEOCODING_API_URL=https://nominatim.openstreetmap.org/reverse
REQUEST_TIMEOUT=10.0

# Local Flask / gunicorn port (Render sets PORT automatically)
PORT=5000